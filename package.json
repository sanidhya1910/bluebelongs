    "jspdf": "^3.0.1",
    "lucide-react": "^0.532.0",
    "masonry-layout": "^4.2.2",
    "next": "15.4.4",
    "next-auth": "^4.24.7",
    "prisma": "^6.12.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.61.1",
    "react-intersection-observer": "^9.16.0",
    "tailwind-merge": "^3.3.1",
    "usehooks-ts": "^3.1.1",
    "wrangler": "^4.31.0",
    "zod": "^4.0.11"
